<Window x:Class="Cybersecurity_Awareness_Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cybersecurity_Awareness_Bot"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Bot" Height="650" Width="950"
        Background="#0B0F19" WindowStartupLocation="CenterScreen" SnapsToDevicePixels="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827" BorderBrush="#1F2937" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="" FontSize="11" FontWeight="Bold" Foreground="#38BDF8"/>
                    <TextBlock Text="CYBERSECURITY BOT" FontSize="20" FontWeight="Black" Foreground="#FFFFFF" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <Border Background="#1E293B" CornerRadius="6" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="CURRENT OPERATOR" FontSize="10" Foreground="#94A3B8" FontWeight="SemiBold"/>
                            <TextBlock x:Name="LblUserName" Text="User" FontSize="15" FontWeight="Bold" Foreground="#00E5FF" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E293B" CornerRadius="6" Padding="12" BorderBrush="#334155" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="THREAT FOCUS AREA" FontSize="10" Foreground="#94A3B8" FontWeight="SemiBold"/>
                            <TextBlock x:Name="LblFavTopic" Text="None Detected Yet" FontSize="14" FontWeight="Bold" Foreground="#10B981" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="2" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="SYSTEM COMMANDS" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>
                        <TextBlock Text="• Inform identity:&#x0a;  'My name is Alice'&#x0a;• Query Threat Profiles:&#x0a;  'Tell me about phishing'&#x0a;  'Password security'&#x0a;  'Suspicious links'&#x0a;• Terminate Session:&#x0a;  'exit'" 
                                   FontSize="12" Foreground="#94A3B8" LineHeight="18" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="3" Text="SECURE CONNECTION V2.0" FontSize="10" FontFamily="Consolas" Foreground="#475569" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#0F172A">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1E293B" Padding="20,0" BorderBrush="#334155" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                        <TextBlock Text="Threat Awareness Engine" FontSize="14" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="ONLINE" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#10B981" FontFamily="Consolas" Background="#064E3B" Padding="6,3" Margin="0"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="ChatScroller" VerticalScrollBarVisibility="Auto" Padding="20">
                <ItemsControl x:Name="ChatLogDisplay">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,8">
                                <Border CornerRadius="{Binding BubbleRadius}" Padding="14,12" MaxWidth="550" 
                                        HorizontalAlignment="{Binding Alignment}" 
                                        Background="{Binding BubbleColor}"
                                        BorderBrush="{Binding BorderColor}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding MessageText}" TextWrapping="Wrap" Foreground="{Binding TextColor}" FontSize="13.5" LineHeight="19"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="4" BorderBrush="#475569" BorderThickness="1" Background="#0F172A">
                        <TextBox x:Name="InputTextBox" FontSize="14" Padding="12,10" 
                                 Background="Transparent" Foreground="#F8FAFC" BorderThickness="0"
                                 CaretBrush="#00E5FF" SelectionBrush="#00E5FF"
                                 KeyDown="InputTextBox_KeyDown" VerticalContentAlignment="Center" Height="40"/>
                    </Border>

                    <Button x:Name="SendButton" Grid.Column="1" Content="SEND COMMAND" Width="140" Margin="15,0,0,0"
                            Background="#00E5FF" Foreground="#0B0F19" FontWeight="Bold" FontSize="12" Click="SendButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#38BDF8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>